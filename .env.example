# Required for production Supabase integration.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USE_SUPABASE_AUTH=true

# Feature flags for controlled rollout
VITE_ENABLE_SERVER_PROGRESS=true
VITE_ENABLE_ADMIN_ANALYTICS=true
VITE_ENABLE_WHATSAPP_AUTOMATION=false

# WhatsApp provider adapter config (optional)
VITE_WHATSAPP_PROVIDER=mock
VITE_WHATSAPP_API_URL=
VITE_WHATSAPP_API_KEY=
